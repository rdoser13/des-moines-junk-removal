---
import { site } from '../data/site';
export interface Props {
  heading?: string;
  body?: string;
}
const {
  heading = "Ready to Clear Out the Clutter?",
  body = "Send a few photos and we'll send back a flat-rate quote the same day. Same-week pickup across the Des Moines metro.",
} = Astro.props;
---
<section class="final-cta">
  <h2>{heading}</h2>
  <p>{body}</p>
  <div class="cta-row">
    <a href={`tel:${site.phoneE164}`} class="btn btn-primary">Call {site.phone}</a>
    <a href="/contact/" class="btn btn-outline-white">Get a Free Quote</a>
  </div>
</section>
